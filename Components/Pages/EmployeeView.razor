@page "/EmployeeView/view/{Id:int}"
@using Gistics.Models
@using Microsoft.AspNetCore.WebUtilities
@inject Gistics.Services.IDataService DataService
@inject NavigationManager Navigation

<h3>Employee details</h3>

@if (item == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@item.FirstName @item.LastName</h5>
            <h6 class="card-subtitle mb-2 text-muted">@item.Title.Name</h6>
            <p class="card-text">Badge #: @item.BadgeNumber</p>
            <p class="card-text">Start Date: @item.StartDate</p>
            @if (item.EndDate != DateOnly.MinValue)
            {
                <p class="card-text">End Date: @item.EndDate.ToString("yyyy-MM-dd")</p>
            }
            
            <button class="btn btn-secondary" @onclick="Back">Back</button>
            <button class="btn btn-outline-primary ms-2" @onclick="() => Edit(item.EmpId)">Edit</button>

            @if (item.EndDate == DateOnly.MinValue)
            {
                <button type="button" class="btn btn-outline-danger ms-2" @onclick="() => ConfirmDelete(item.EmpId)">Terminate</button>
            }
            else
            {
                <button type="button" class="btn btn-third ms-2" @onclick="() => ConfirmDelete(item.EmpId)">Reinstate</button>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "id")]
    public int Id { get; set; }

    private Employees item;

    //Use OnParametersSetAsync so query-string or route changes are handled
    protected override async Task OnParametersSetAsync()
    {
        try
        {
            item = await DataService.GetEmployeeAsync(Id);

            if (item == null)
                Navigation.NavigateTo("/EmployeesView");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error parsing 'id' from query string: {ex.Message}");
            Navigation.NavigateTo("/EmployeesView");
            return;
        }
    }

    private void Back() => Navigation.NavigateTo("/EmployeesView");
    private void Edit(int id) => Navigation.NavigateTo($"/EmployeeView/edit/{id}");

    private async Task ConfirmDelete(int id)
    {
        try
        {
            var EmpTerminatedbool = await DataService.TerminateEmployeeAsync(Id);
            if (!EmpTerminatedbool)
            {
                Navigation.NavigateTo("/EmployeesView");
            }
            else
            {
                throw new Exception("Failed to terminate employee.");
            }

            // If you changed model after async calls, ensure the UI updates
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"EmployeeEdit.ConfirmDelete error: {ex}");
        }
    }
}