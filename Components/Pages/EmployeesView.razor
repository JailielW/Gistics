@page "/EmployeesView"
@using Gistics.Models
@inject Gistics.Services.IDataService DataService
@inject NavigationManager Navigation

<h3>Employees</h3>

<div class="mb-3">
    <button type="button" class="btn btn-go" @onclick="CreateNew">New Employee</button>
</div>

@if (employees == null)
{
    <p><em>Loading...</em></p>
}
else if (!employees.Any())
{
    <p><em>No items yet.</em></p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title Name</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Badge Number</th>
                <th>Start Date</th>
                <th>End Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in employees)
            {
                <tr @key="t.EmpId">
                    <td>@t.Title.Name</td>
                    <td>@t.FirstName</td>
                    <td>@t.LastName</td>
                    <td>@t.BadgeNumber</td>
                    <td>@t.StartDate</td>
                    @if(t.EndDate != DateOnly.MinValue)
                    {<td>@t.EndDate</td>}
                    else{<td></td>}
        
                    <td>
                        <button type="button" class="btn btn-sm btn-outline-primary me-1" @onclick="() => View(t.EmpId)">View</button>

                        <button type="button" class="btn btn-sm btn-outline-secondary me-1" @onclick="() => Edit(t.EmpId)">Edit</button>

                        @if (t.EndDate == DateOnly.MinValue)
                        {
                            <button type="button" class="btn btn-outline-danger ms-2" @onclick="() => ConfirmDelete(t.EmpId)">Terminate</button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-third ms-2" @onclick="() => ConfirmDelete(t.EmpId)">Reinstate</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (deleteId != 0)
{
    <div class="modal show d-block" tabindex="-1" role="dialog" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this record?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="() => Delete(deleteId)">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code 
{
    private List<Employees>? employees;
    bool Deleted = false;
    private int deleteId = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            employees = await DataService.GetAllEmployeesAsync();
        }
        catch (Exception ex)
        {
            // Surface initialization errors (check browser console/server logs)
            Console.Error.WriteLine($"OnInitializedAsync error: {ex}");
            employees = new List<Employees>();
        }
    }

    private void CreateNew() => Navigation.NavigateTo("/EmployeeView/new");
    private void Edit(int id) => Navigation.NavigateTo($"/EmployeeView/edit/{id}");
    private void View(int id) => Navigation.NavigateTo($"/EmployeeView/view/{id}");

    private void ConfirmDelete(int id)
    {
        deleteId = id;
        StateHasChanged();
    }

    private async Task Delete(int id)
    {
        try
        {
            var EmpTerminatedbool = await DataService.TerminateEmployeeAsync(id);
            if (!EmpTerminatedbool)
            {
                // refresh list after successful termination
                employees = await DataService.GetAllEmployeesAsync();
                deleteId = 0;
            }
            else
            {
                throw new Exception("Failed to terminate employee.");
            }

            // If you changed model after async calls, ensure the UI updates
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"EmployeesView.Delete error: {ex}");
        }
    }

    private void CancelDelete()
    {
        deleteId = 0;
        StateHasChanged();
    }

    // private async Task DeleteAsync()
    // {
    //     //await TodoService.DeleteAsync(deleteId.Value);
    //     Deleted = await DataService.DeleteAsync(deleteId);

    //     // refresh list after delete
    //     employees = await DataService.GetAllEmployeesAsync();
    //     StateHasChanged();
    // }
}